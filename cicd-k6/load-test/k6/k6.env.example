# Copy this file to .env on the k6 server and update the addresses.

# Shoply application target.
BASE_URL=http://<SHOPLY_TARGET>

# Prometheus remote write endpoint. The /api/v1/write path is required.
PROMETHEUS_URL=http://<PROMETHEUS_IP>:9090/api/v1/write

# Test account pool. VU 1 uses test1@shoply.com, VU 400 uses test400@shoply.com.
ACCOUNT_COUNT=2000

# Common password for test accounts.
TEST_PASSWORD=Test1234!
