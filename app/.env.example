# PostgreSQL
POSTGRES_DB=shoply
POSTGRES_USER=shoply
POSTGRES_PASSWORD=shoply1234
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
