PRODUCT_SERVICE_URL=http://product:4001
INVENTORY_SERVICE_URL=http://inventory:4002
ORDER_SERVICE_URL=http://order:4003
PAYMENT_SERVICE_URL=http://payment:4004

# Service Ports
USER_PORT=4005
PRODUCT_PORT=4001
INVENTORY_PORT=4002
ORDER_PORT=4003
PAYMENT_PORT=4004
GATEWAY_PORT=4000
